class Person:
    def walk(self):
        print("Person can walk")
    def talk(self):
        print("Person can talk")

class Teacher(Person):
    def teach(self):
        print("Teacher can teach")

class Student(Person):
    def study(self):
        print("Student can study")

t = Teacher()
s = Student()

t.walk()
t.talk()
t.teach()

s.walk()
s.talk()
s.study()
